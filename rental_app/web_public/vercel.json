{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/login", "destination": "/login.html" },
    { "source": "/account", "destination": "/account.html" },
    { "source": "/ai-result", "destination": "/ai_result.html" },
    { "source": "/compare", "destination": "/compare.html" },
    { "source": "/assistant", "destination": "/assistant.html" },
    { "source": "/contract-analysis", "destination": "/contract_analysis.html" },
    { "source": "/analysis-history", "destination": "/analysis_history.html" },
    { "source": "/history", "destination": "/history.html" },
    { "source": "/history-detail", "destination": "/history_detail.html" },
    { "source": "/register", "destination": "/register.html" },
    { "source": "/result/:path*", "destination": "/result.html" },
    { "source": "/reputation", "destination": "/reputation.html" },
    { "source": "/start", "destination": "/start.html" },
    { "source": "/check-contract", "destination": "/check_contract.html" }
