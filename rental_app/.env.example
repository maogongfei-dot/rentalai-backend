# RentalAI — 环境变量模板（复制为 `.env` 后按需填写；勿提交真实密钥）
# 本地 Demo：可不创建 .env，默认监听 http://127.0.0.1:8000 即可。
# Phase4：`python run.py` 会自动读取同目录下的 `.env`（无需 python-dotenv）。
# 其他启动方式：在 shell 中 export 下列变量。
#
# PORT：Render / Heroku 等会注入；render.yaml 与 Procfile 的启动命令使用 $PORT。
#       应用 Python 代码不读取 PORT；本地开发通常不必在 .env 里写 PORT。

# ---------------------------------------------------------------------------
# Phase4 — 一键 Web 产品（run.py：FastAPI + / /login /history 等）
# ---------------------------------------------------------------------------
# 监听地址（本地默认 127.0.0.1；未设置 RENTALAI_HOST 且存在 PORT 时默认 0.0.0.0）
# RENTALAI_HOST=127.0.0.1
# 端口（Heroku/Render 等会注入 PORT；也可用 RENTALAI_PORT 覆盖）
# RENTALAI_PORT=8000
# 开发热重载（1/true/yes）
# RENTALAI_RELOAD=0
# 调试日志
# RENTALAI_DEBUG=0
# 预留：未来签名/会话（当前内存 token 未使用）
# RENTALAI_SECRET_KEY=change-me-in-production

# ---------------------------------------------------------------------------
# Phase5 — 公网部署（Render 等）
# ---------------------------------------------------------------------------
# Render/Heroku 会注入 PORT；勿在平台控制台设置 RENTALAI_RELOAD=1（生产勿热重载）。
# 生产建议关闭调试：
# RENTALAI_DEBUG=0
#
# SQLite 与 task_store 默认写在 rental_app 目录下；无持久盘时实例重建会丢库。
# 在 Render 为该 Web Service 挂载 Disk 后，可指向挂载路径，例如：
# RENTALAI_RECORDS_DB_PATH=/data/.rentalai_records.db
# RENTALAI_TASK_STORE_PATH=/data/.task_store.json
#
# Playwright 浏览器缓存（构建阶段已 install；运行时可选自定义缓存目录）
# PLAYWRIGHT_BROWSERS_PATH=/opt/render/.cache/ms-playwright

# ---------------------------------------------------------------------------
# Streamlit 前端（官方变量，详见 https://docs.streamlit.io/ ）
# ---------------------------------------------------------------------------
# 监听地址；公网部署时常用 0.0.0.0
# STREAMLIT_SERVER_ADDRESS=127.0.0.1
# 端口
# STREAMLIT_SERVER_PORT=8501

# ---------------------------------------------------------------------------
# Web UI ↔ FastAPI（由 app_web.py 读取）
# ---------------------------------------------------------------------------
# 关闭「Use local engine」时，单条 Analyze / 部分路径请求的 API 根地址（无尾部斜杠）
# 本地开发：http://127.0.0.1:8000
# 线上部署：填已部署 rentalai-api 的公网 URL，例如 https://rentalai-api-xxxx.onrender.com
RENTALAI_API_URL=http://127.0.0.1:8000

# 为 1 / true / yes 时：单条 Analyze Property 使用进程内引擎，不请求 HTTP
RENTALAI_USE_LOCAL=1

# ---------------------------------------------------------------------------
# 数据持久化（由 data/storage/listing_storage.py 读取，可选）
# ---------------------------------------------------------------------------
# 未设置时默认：rental_app/data/listings.json（相对包内路径）
# RENTALAI_LISTINGS_PATH=/var/lib/rentalai/listings.json

# ---------------------------------------------------------------------------
# Playwright / 抓取（可选；官方与运维常用）
# ---------------------------------------------------------------------------
# 浏览器二进制缓存目录（CI、只读文件系统或自定义缓存位置时使用）
# PLAYWRIGHT_BROWSERS_PATH=/path/to/playwright-browsers

# ---------------------------------------------------------------------------
# 性能调优（可选）— 批量分析并行度与上限
# ---------------------------------------------------------------------------
# RENTALAI_BATCH_MAX=50
# RENTALAI_BATCH_WORKERS=4

# ---------------------------------------------------------------------------
# 超时控制（可选）— 秒
# ---------------------------------------------------------------------------
# 单平台 scraper pipeline 最大运行时间
# RENTALAI_SOURCE_TIMEOUT=120
# 前端 run_real_listings_analysis 整体超时
# RENTALAI_REAL_ANALYSIS_TIMEOUT=180

# ---------------------------------------------------------------------------
# 异步任务持久化（可选）— JSON 文件路径
# ---------------------------------------------------------------------------
# 未设置时默认：rental_app/.task_store.json（紧邻 task_store.py）
# RENTALAI_TASK_STORE_PATH=/var/lib/rentalai/task_store.json

# ---------------------------------------------------------------------------
# 运行环境标签（约定变量；当前主业务代码未读取，仅供部署/监控脚本使用）
# ---------------------------------------------------------------------------
# RENTALAI_ENV=development

# ---------------------------------------------------------------------------
# 第三方 API Key
# ---------------------------------------------------------------------------
# 当前 RentalAI 核心分析链与抓取不依赖外部付费 API；若后续接入 LLM/地图等，在此追加：
# SOME_VENDOR_API_KEY=

# ---------------------------------------------------------------------------
# 报警 Webhook（可选）— 配置后 P0/P1 级 alert 自动 POST 到该 URL
# ---------------------------------------------------------------------------
# Slack:   https://hooks.slack.com/services/T.../B.../xxx
# Discord: https://discord.com/api/webhooks/.../slack
# RENTALAI_ALERT_WEBHOOK=
